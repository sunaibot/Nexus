{
  "name": "nexus-project",
  "private": true,
  "version": "0.1.0",
  "description": "Nexus - 智能书签管理系统 (Inspired by NOWEN)",
  "scripts": {
    "dev:frontend": "cd apps/frontend && npm run dev",
    "dev:manager": "cd apps/manager && npm run dev",
    "dev:server": "cd apps/server && npm run dev",
    "build:frontend": "cd apps/frontend && npm run build",
    "build:manager": "cd apps/manager && npm run build",
    "build:server": "cd apps/server && npm run build",
    "build": "npm run build:frontend && npm run build:manager && npm run build:server",
    "preview:frontend": "cd apps/frontend && npm run preview",
    "preview:manager": "cd apps/manager && npm run preview",
    "start:server": "cd apps/server && npm run start",
    "test:frontend": "cd apps/frontend && npm run test",
    "test:manager": "cd apps/manager && npm run test"
  },
  "keywords": [
    "bookmark",
    "navigation",
    "dashboard",
    "nexus"
  ],
