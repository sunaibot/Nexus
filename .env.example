# ============================================
# Nexus 环境变量配置
# ⚠️  部署前必须修改所有安全相关变量！
# ============================================

# ============================================
# 安全密钥（必须修改！使用强随机字符串）
# ============================================

# 🔐 如何生成安全密钥（选择一种方法）：
#
# 【方法1】在线生成（最简单，推荐新手）
# 1. 打开网站: https://www.random.org/passwords/?num=5&len=32&format=html&rnd=new
# 2. 复制生成的随机字符串
# 3. 或者使用: https://1password.com/password-generator/
#
# 【方法2】Windows PowerShell（无需安装软件）
# 1. 按 Win+X，选择 "Windows PowerShell"
# 2. 输入: -join ((65..90) + (97..122) + (48..57) | Get-Random -Count 32 | % {[char]$_})
# 3. 复制输出的字符串
#
# 【方法3】命令行（适合技术人员）
# openssl rand -base64 32
#
# ⚠️  要求：至少32个字符，包含大小写字母和数字
# ⚠️  JWT_SECRET 和 SESSION_SECRET 必须使用不同的值！
# ============================================

# JWT 签名密钥（用于 Token 签名）
JWT_SECRET=change-this-to-a-random-string-min-32-chars

# Session 签名密钥（用于 Session 签名）
SESSION_SECRET=change-this-to-a-different-random-string-min-32-chars

# ============================================
# 端口配置（建议修改默认值）
# ============================================

# 后端服务端口（映射到主机的端口）
SERVER_PORT=8787

# 前端服务端口
FRONTEND_PORT=5173

# 管理后台端口
MANAGER_PORT=5174

# ============================================
# 数据存储路径
# ============================================

# 数据目录路径（相对于 docker-compose.yml 的路径）
DATA_PATH=./data

# ============================================
# 服务器配置
# ============================================

# 环境模式（production/development）
NODE_ENV=production

# 允许跨域访问的域名
# 生产环境建议设置为具体域名，如: https://nav.yourdomain.com,https://admin.yourdomain.com
# 多个域名用逗号分隔
ALLOWED_ORIGINS=

# 日志级别（debug/info/warn/error）
LOG_LEVEL=info

# ============================================
# 可选：外部服务配置
# ============================================

# 天气 API 密钥（如需天气功能）
# WEATHER_API_KEY=your-weather-api-key

# ============================================
# 可选：高级配置
# ============================================

# 请求体大小限制
MAX_BODY_SIZE=10mb

# 文件上传大小限制（字节）
MAX_FILE_SIZE=10485760

# ============================================
# 安全检查清单
# ============================================
# □ JWT_SECRET 已修改为随机字符串（最少32字符）
# □ SESSION_SECRET 已修改为不同的随机字符串
# □ 修改了默认端口（SERVER_PORT, FRONTEND_PORT, MANAGER_PORT）
# □ 设置了 ALLOWED_ORIGINS 限制访问来源
# □ 数据目录已设置正确的权限（chmod 700）
