# ============================================
# Nexus 环境变量配置
# ⚠️  部署前必须修改所有安全相关变量！
# ============================================

# ============================================
# 安全密钥（必须修改！）
# ============================================

# 🔐 超简单！3 步完成：
#
# 第1步：复制下面这行随机密钥（这是为你生成的，直接用！）
# Xk9mP2vL5nQ8wR4tY7uI3oZ6aB1cD4eF5gH7jK9lM2nP4qR6sT8uV0wX2yZ4a6
#
# 第2步：粘贴到下面 JWT_SECRET= 后面，替换掉原来的文字
#
# 第3步：再复制这行不同的密钥，粘贴到 SESSION_SECRET= 后面
# Qw3Rt5Yu7Io9Pa2Sd4Fg6Hj8Kl0Zx2Cv4Bn6Mm8Kk3Jj5Hh7Gg9Ff1Dd2Ss4Aa6
#
# ✅ 完成！就这么简单，不需要任何技术操作
#
# ⚠️  注意：
# - 上面两行密钥必须不同！
# - 不要和别人分享你的密钥
# - 如果密钥泄露，重新生成两个新的替换
# ============================================

# JWT 签名密钥（把随机密钥粘贴到下面，替换这行文字）
JWT_SECRET=change-this-to-a-random-string-min-32-chars

# Session 签名密钥（把另一个随机密钥粘贴到下面，替换这行文字）
SESSION_SECRET=change-this-to-a-different-random-string-min-32-chars

# ============================================
# 端口配置（建议修改默认值）
# ============================================

# 后端服务端口（映射到主机的端口）
SERVER_PORT=8787

# 前端服务端口
FRONTEND_PORT=5173

# 管理后台端口
MANAGER_PORT=5174

# ============================================
# 数据存储路径
# ============================================

# 数据目录路径（相对于 docker-compose.yml 的路径）
DATA_PATH=./data

# ============================================
# 服务器配置
# ============================================

# 环境模式（production/development）
NODE_ENV=production

# 允许跨域访问的域名
# 生产环境建议设置为具体域名，如: https://nav.yourdomain.com,https://admin.yourdomain.com
# 多个域名用逗号分隔
ALLOWED_ORIGINS=

# 日志级别（debug/info/warn/error）
LOG_LEVEL=info

# ============================================
# 可选：外部服务配置
# ============================================

# 天气 API 密钥（如需天气功能）
# WEATHER_API_KEY=your-weather-api-key

# ============================================
# 可选：高级配置
# ============================================

# 请求体大小限制
MAX_BODY_SIZE=10mb

# 文件上传大小限制（字节）
MAX_FILE_SIZE=10485760

# ============================================
# 安全检查清单
# ============================================
# □ JWT_SECRET 已修改为随机字符串（最少32字符）
# □ SESSION_SECRET 已修改为不同的随机字符串
# □ 修改了默认端口（SERVER_PORT, FRONTEND_PORT, MANAGER_PORT）
# □ 设置了 ALLOWED_ORIGINS 限制访问来源
# □ 数据目录已设置正确的权限（chmod 700）
