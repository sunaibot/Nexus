# ============================================
# Nexus 最小化环境变量配置
# ⚠️  部署前必须修改安全相关变量！
# ============================================

# ============================================
# 安全密钥（必须修改！）
# ============================================

# 🔐 设置方法：
# 想一个你自己的密码（至少8位，比如手机号+名字拼音）
# 示例：13812345678zhangsan
# 系统会自动用你的密码生成安全密钥
#
# ⚠️  记住你的密码，重装系统时需要相同的密码才能恢复数据！
# ⚠️  不要告诉别人你的密码！
# ============================================

# 你的密码（至少8位，用你自己的！）
YOUR_PASSWORD=填上你自己的密码

# ============================================
# 端口配置（建议修改默认值）
# ============================================

# 后端服务端口
SERVER_PORT=8787

# 前端服务端口
FRONTEND_PORT=8785

# 管理后台端口
MANAGER_PORT=8786

# ============================================
# 前端构建配置
# ============================================

# API 基础地址
# 开发环境：http://localhost:8787
# 生产环境：留空则使用相对路径（配合 Nginx 代理）
VITE_API_BASE=

# ============================================
# 安全检查清单
# ============================================
# □ YOUR_PASSWORD 已修改为至少8位的自定义密码
# □ 修改了默认端口（可选，但建议修改）
# □ 数据目录已设置正确的权限（chmod 700）

# ============================================
# 💡 其他配置已移至管理后台【系统配置】页面
#    包括：站点标题、日志级别、跨域设置等
#    访问：http://localhost:8786/admin/system-configs
# ============================================
