# ============================================
# Nexus 环境变量配置
# ⚠️  部署前必须修改所有安全相关变量！
# ============================================

# ============================================
# 安全密钥（必须修改！）
# ============================================

# 🔐 小学生都会的方法！只需2步：
#
# 第1步：想一个你自己的密码（至少8位，比如你的手机号+名字拼音）
#        示例：13812345678zhangsan
#        示例：mima2024@home
#        示例：woaini1234
#
# 第2步：把你想的密码填到下面 = 后面
#
# ✅ 完成！系统会自动用你的密码生成安全密钥
#
# ⚠️  记住你的密码，以后重装系统时要用相同的密码才能恢复数据！
# ⚠️  不要告诉别人你的密码！
# ============================================

# 你的密码（至少8位，用你自己的！）
YOUR_PASSWORD=填上你自己的密码

# ============================================
# 以下密钥由系统根据你的密码自动生成，无需手动修改
# 如果你非要手动设置，取消下面两行注释并填写
# ============================================

# JWT 签名密钥（系统自动生成，无需修改）
JWT_SECRET=auto-generated-from-your-password

# Session 签名密钥（系统自动生成，无需修改）
SESSION_SECRET=auto-generated-from-your-password

# ============================================
# 端口配置（建议修改默认值）
# ============================================

# 后端服务端口（映射到主机的端口）
SERVER_PORT=8787

# 前端服务端口
FRONTEND_PORT=5173

# 管理后台端口
MANAGER_PORT=5174

# ============================================
# 数据存储路径
# ============================================

# 数据目录路径（相对于 docker-compose.yml 的路径）
DATA_PATH=./data

# ============================================
# 服务器配置
# ============================================

# 环境模式（production/development）
NODE_ENV=production

# 允许跨域访问的域名
# 生产环境建议设置为具体域名，如: https://nav.yourdomain.com,https://admin.yourdomain.com
# 多个域名用逗号分隔
ALLOWED_ORIGINS=

# 日志级别（debug/info/warn/error）
LOG_LEVEL=info

# ============================================
# 可选：外部服务配置
# ============================================

# 天气 API 密钥（如需天气功能）
# WEATHER_API_KEY=your-weather-api-key

# ============================================
# 可选：高级配置
# ============================================

# 请求体大小限制
MAX_BODY_SIZE=10mb

# 文件上传大小限制（字节）
MAX_FILE_SIZE=10485760

# ============================================
# 安全检查清单
# ============================================
# □ JWT_SECRET 已修改为随机字符串（最少32字符）
# □ SESSION_SECRET 已修改为不同的随机字符串
# □ 修改了默认端口（SERVER_PORT, FRONTEND_PORT, MANAGER_PORT）
# □ 设置了 ALLOWED_ORIGINS 限制访问来源
# □ 数据目录已设置正确的权限（chmod 700）
